---
import fs from "node:fs";
import path from "node:path";

interface Item {
  name: string;
  url: string;
  kind: string;
}
interface Data {
  folderName: string;
  folderUrl: string;
  note: string;
  items: Item[];
}

const data: Data = JSON.parse(
  fs.readFileSync(path.resolve("public/data/ingresados.json"), "utf-8"),
);

const GROUPS: { kind: string; label: string }[] = [
  { kind: "consolidado", label: "Listados consolidados" },
  { kind: "hospital", label: "Por hospital" },
  { kind: "otro", label: "Otros listados" },
];

const byKind = (k: string) => data.items.filter((i) => i.kind === k);
const groups = GROUPS.filter((g) => byKind(g.kind).length > 0);
---

<section id="tab-ingresados" class="tab-panel">
  <header class="panel-head">
    <p class="panel-eyebrow">Personas ingresadas</p>
    <h2 class="panel-title">Listados de ingresados</h2>
    <p class="panel-intro">
      Listados de personas ingresadas en hospitales tras el sismo, recopilados en
      Google Drive. Los formatos varían (PDF, hojas, carpetas); cada enlace abre
      el archivo original en una pestaña nueva.
    </p>
  </header>

  <div class="ing-top">
    <a class="folder-btn" href={data.folderUrl} target="_blank" rel="noopener noreferrer">
      📁 Abrir carpeta completa en Drive · {data.folderName}
    </a>
    <span class="ing-updated" id="ing-updated"></span>
  </div>

  <input
    type="search"
    id="ing-search"
    class="ing-search"
    placeholder="Filtrar listados (ej: Vargas, consolidado…)"
    autocomplete="off"
    aria-label="Filtrar listados"
  />

  <div id="ing-groups">
    {
      groups.map((g) => (
        <div class="ing-group">
          <h3 class="ing-group-title">{g.label}</h3>
          <ul class="ing-list">
            {byKind(g.kind).map((item) => (
              <li>
                <a class="ing-link" href={item.url} target="_blank" rel="noopener noreferrer">
                  <span class="ing-name">{item.name}</span>
                  <span class="ing-go" aria-hidden="true">↗</span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))
    }
  </div>
  <p id="ing-empty" class="ing-empty" hidden>No hay listados que coincidan con el filtro.</p>

  <p class="ing-note">
    Información recopilada por terceros y alojada en Google Drive. Verifica los
    datos directamente con el hospital o la fuente oficial.
  </p>
</section>

<script>
  // Live refresh: re-enumerate the Drive folder on every load via the serverless
  // function (so newly added files appear), falling back to the static snapshot.
  (function () {
    const GROUPS = [
      { kind: "consolidado", label: "Listados consolidados" },
      { kind: "hospital", label: "Por hospital" },
      { kind: "otro", label: "Otros listados" },
    ];
    const esc = (s: string) =>
      String(s).replace(/[&<>"]/g, (c) =>
        ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;" })[c]!,
      );

    function render(items: any[]) {
      const root = document.getElementById("ing-groups");
      if (!root || !items?.length) return;
      let html = "";
      for (const g of GROUPS) {
        const list = items.filter((i) => i.kind === g.kind);
        if (!list.length) continue;
        html += `<div class="ing-group"><h3 class="ing-group-title">${esc(g.label)}</h3><ul class="ing-list">`;
        for (const it of list) {
          html += `<li><a class="ing-link" href="${esc(it.url)}" target="_blank" rel="noopener noreferrer"><span class="ing-name">${esc(it.name)}</span><span class="ing-go" aria-hidden="true">↗</span></a></li>`;
        }
        html += "</ul></div>";
      }
      root.innerHTML = html;
    }

    async function load() {
      for (const url of ["/.netlify/functions/ingresados", "/data/ingresados.json"]) {
        try {
          const r = await fetch(url, { cache: "no-store" });
          if (!r.ok) continue;
          const d = await r.json();
          if (!d.items?.length) continue;
          render(d.items);
          applyFilter();
          const live = url.includes("functions");
          const el = document.getElementById("ing-updated");
          if (el)
            el.textContent = live
              ? `${d.items.length} archivos · actualizado ahora`
              : `${d.items.length} archivos`;
          return;
        } catch {
          /* try next */
        }
      }
    }

    // Text filter over the listed files (re-applied after each live re-render).
    const searchEl = document.getElementById("ing-search") as HTMLInputElement | null;
    function applyFilter() {
      const q = (searchEl?.value || "").trim().toLowerCase();
      const root = document.getElementById("ing-groups");
      if (!root) return;
      let any = false;
      root.querySelectorAll<HTMLElement>(".ing-group").forEach((g) => {
        let groupAny = false;
        g.querySelectorAll<HTMLElement>(".ing-list > li").forEach((li) => {
          const show = !q || (li.textContent || "").toLowerCase().includes(q);
          li.hidden = !show;
          if (show) groupAny = true;
        });
        g.hidden = !groupAny;
        if (groupAny) any = true;
      });
      const empty = document.getElementById("ing-empty");
      if (empty) empty.hidden = any;
    }
    searchEl?.addEventListener("input", applyFilter);

    applyFilter(); // filter the server-rendered list immediately
    load();
  })();
</script>

<style>
  .tab-panel { display: none; }
  .tab-panel.active { display: block; }

  .ing-top { display: flex; align-items: center; flex-wrap: wrap; gap: 12px; margin-bottom: 16px; }
  .ing-updated { font-family: var(--font-mono); font-size: 11px; color: var(--muted); }

  .ing-search {
    width: 100%;
    max-width: 720px;
    font-family: var(--font-body);
    font-size: 14px;
    padding: 11px 14px;
    border: 1px solid var(--line);
    border-radius: 10px;
    background: var(--card);
    color: var(--text);
    margin-bottom: 24px;
  }
  .ing-search:focus { outline: none; border-color: var(--gold); }

  .ing-empty {
    font-size: 14px;
    color: var(--muted);
    background: var(--card);
    border: 1px dashed var(--line);
    border-radius: 10px;
    padding: 20px;
    text-align: center;
    max-width: 720px;
  }

  /* Global so the client-side re-rendered list (injected via innerHTML, without
     Astro's scope attribute) is styled the same as the server-rendered one. */
  :global(.folder-btn) {
    display: inline-block;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 14px;
    text-decoration: none;
    color: var(--ink);
    background: var(--gold);
    padding: 12px 18px;
    border-radius: 10px;
    transition: background 0.15s;
  }
  :global(.folder-btn:hover) { background: var(--gold-deep); color: #fff; }

  :global(.ing-group) { margin-bottom: 26px; max-width: 720px; }
  :global(.ing-group-title) {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
    margin: 0 0 10px;
    padding-bottom: 7px;
    border-bottom: 1px solid var(--line);
  }
  :global(.ing-list) { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 7px; }
  :global(.ing-link) {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 13px 16px;
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: 10px;
    text-decoration: none;
    transition: border-color 0.15s, box-shadow 0.15s, transform 0.15s;
  }
  :global(.ing-link:hover) {
    border-color: #d3d8e2;
    box-shadow: 0 4px 14px rgba(20, 33, 61, 0.08);
    transform: translateY(-1px);
  }
  :global(.ing-name) { font-size: 14px; color: var(--ink); font-weight: 600; }
  :global(.ing-go) { font-family: var(--font-mono); color: var(--gold-deep); flex-shrink: 0; }

  .ing-note {
    font-size: 12px;
    color: var(--muted);
    font-style: italic;
    margin: 24px 0 0;
    max-width: 720px;
  }
</style>
