---
import type { ImageEntry } from "../types";
import { VE_STATE_COORDS, compilationStates } from "../lib/centers";

interface Props {
  entries: ImageEntry[];
}

const { entries } = Astro.props;

interface MapPoint {
  id: string;
  lat: number;
  lng: number;
  category: ImageEntry["category"];
  title: string;
  org: string;
  detail: string;
  country: string;
  state: string;
  needs: string[];
  phone: string;
  whatsapp: string;
  waOnly: boolean;
  people: { name: string; contact: string }[];
}

// Build map points. A multi-state compilation (one flyer listing points across
// several states) is exploded into one marker per point, placed in its state.
const points: MapPoint[] = [];
for (const e of entries) {
  const states = compilationStates(e);
  if (states) {
    (e.collectionPoints || []).forEach((p, i) => {
      const base = p.state ? VE_STATE_COORDS[p.state] : undefined;
      if (!base) return;
      points.push({
        id: `${e.filename}#${i}`,
        lat: base.lat + ((i % 3) - 1) * 0.05,
        lng: base.lng + (Math.floor(i / 3) - 1) * 0.05,
        category: e.category,
        title: p.location,
        org: e.title,
        detail: p.state || "",
        country: e.location.country || "Sin especificar",
        state: p.state || "Sin especificar",
        needs: (e.needs || []).slice(0, 6),
        phone: "",
        whatsapp: "",
        waOnly: false,
        people: [],
      });
    });
  } else if (e.coords) {
    points.push({
      id: e.filename,
      lat: e.coords.lat,
      lng: e.coords.lng,
      category: e.category,
      title: e.title,
      org: e.organization || "",
      detail:
        e.location.address ||
        [e.location.city, e.location.state].filter(Boolean).join(", "),
      country: e.location.country || "Sin especificar",
      state: e.location.state || "Sin especificar",
      needs: (e.needs || []).slice(0, 6),
      phone: e.contact?.phone || "",
      whatsapp: e.contact?.whatsapp || "",
      waOnly: !!e.contact?.whatsappOnly,
      // Surface every listed professional's phone in the map popup (AID: psi-2
      // gathers several psychologists under one location).
      people: (e.people || [])
        .filter((pp) => pp.contact)
        .map((pp) => ({ name: pp.name, contact: pp.contact || "" })),
    });
  }
}

// Group the side list by country -> state (Venezuela first).
const grouped = points.reduce(
  (acc, p) => {
    (acc[p.country] ??= {});
    (acc[p.country][p.state] ??= []).push(p);
    return acc;
  },
  {} as Record<string, Record<string, typeof points>>,
);
const countries = Object.keys(grouped).sort((a, b) => {
  if (a === "Venezuela") return -1;
  if (b === "Venezuela") return 1;
  return a.localeCompare(b);
});

const acopiosCount = points.filter((p) => p.category === "center").length;
const personalCount = points.filter((p) => p.category === "professional").length;

// Serialize the points for the bundled module script. We can't use `define:vars`
// (that forces an inline script, which can't `import` the quakes helpers), so we
// hand the data over via a JSON <script> tag. Escape `<` to keep any stray
// "</script>" in the data from breaking out of the tag.
const pointsJson = JSON.stringify(points).replace(/</g, "\\u003c");
---

<section id="tab-mapa" class="tab-panel">
  <header class="panel-head">
    <p class="panel-eyebrow">Mapa de puntos</p>
    <h2 class="panel-title">Todo sobre el terreno</h2>
    <p class="panel-intro">
      Centros de acopio, ayuda profesional, sismos recientes e incidentes
      reportados (colapsos, fugas, vías), centrados en Venezuela. Usa la lupa del
      mapa para buscar cualquier lugar.
    </p>
  </header>

  <div class="legend" role="group" aria-label="Filtrar puntos por tipo">
    <button type="button" class="lg active" data-type="center" aria-pressed="true">
      <span class="lg-dot center"></span> Acopios (<span class="lg-n">{acopiosCount}</span>)
    </button>
    <button type="button" class="lg active" data-type="professional" aria-pressed="true">
      <span class="lg-dot prof"></span> Personal (<span class="lg-n">{personalCount}</span>)
    </button>
    <button type="button" class="lg active" data-type="quake" aria-pressed="true">
      <span class="lg-dot quake"></span> Sismos recientes <span id="quake-count" class="lg-n">…</span>
    </button>
    <button type="button" class="lg active" data-type="sos" aria-pressed="true">
      <span class="lg-dot sos"></span> Incidentes <span id="sos-count" class="lg-n">…</span>
    </button>
    <span class="quake-src">Sismos: USGS · Incidentes: SOS Venezuela 2026</span>
    <button type="button" id="quake-refresh" class="map-reset ghost">⟳ Actualizar sismos</button>
    <button type="button" id="map-reset" class="map-reset">⟲ Centrar en Venezuela</button>
  </div>
  <p id="quake-error" class="quake-error" hidden>
    No se pudieron cargar los sismos en este momento.
  </p>

  <div class="map-layout">
    <div id="map" class="map-pane" role="application" aria-label="Mapa de puntos de ayuda y sismos"></div>

    <div class="list-pane" id="map-list">
      <div class="subtabs" role="tablist" aria-label="Vista del listado">
        <button type="button" class="subtab active" data-view="lugares" role="tab" aria-selected="true">Lugares</button>
        <button type="button" class="subtab" data-view="sismos" role="tab" aria-selected="false">Sismos</button>
      </div>

      <div id="view-sismos" hidden>
        <div class="quake-controls">
          <div class="quake-stamp">
            <span><strong id="quake-shown">0</strong> sismos · act. <span id="quake-updated">—</span></span>
            <button type="button" id="quake-refresh2" class="qbtn" title="Actualizar sismos">⟳</button>
          </div>
          <div class="qmag-group" role="group" aria-label="Magnitud mínima">
            <button type="button" class="qmag-btn active" data-min="2.5">≥2.5</button>
            <button type="button" class="qmag-btn" data-min="4">≥4.0</button>
            <button type="button" class="qmag-btn" data-min="5">≥5.0</button>
          </div>
          <div class="quake-selects">
            <select id="quake-date" aria-label="Rango de fecha">
              <option value="month">Este mes</option>
              <option value="week">Esta semana</option>
              <option value="today">Hoy</option>
            </select>
            <select id="quake-depth" aria-label="Profundidad">
              <option value="any">Cualquier prof.</option>
              <option value="surface">Superficial ≤10km</option>
              <option value="shallow">Somero 10–70km</option>
              <option value="deep">Profundo &gt;70km</option>
            </select>
          </div>
          <button type="button" id="quake-clear" class="qclear" hidden>
            Limpiar selección (<span id="quake-seln">0</span>)
          </button>
        </div>
        <ul id="quake-list" class="quake-list"></ul>
        <p id="quake-empty" class="list-empty" hidden>No hay sismos recientes con los filtros activos.</p>
      </div>

      <div id="view-lugares">
      <div class="list-filters">
        <select id="map-country" aria-label="Filtrar por país">
          <option value="">Todos los países</option>
          {countries.map((c) => <option value={c}>{c}</option>)}
        </select>
        <select id="map-state" aria-label="Filtrar por estado">
          <option value="">Todos los estados</option>
        </select>
      </div>

      {countries.map((country) => (
        <div class="country-block">
          <h3 class="country-name">{country}</h3>
          {Object.entries(grouped[country])
            .sort(([a], [b]) => a.localeCompare(b))
            .map(([state, items]) => (
              <div class="state-block">
                <h4 class="state-name">
                  {state} <span class="count">{items.length}</span>
                </h4>
                <ul class="point-list">
                  {items.map((p) => (
                    <li class="point-item" data-cat={p.category} data-country={p.country} data-state={p.state}>
                      <button type="button" class={`point ${p.category}`} data-id={p.id}>
                        <span class="dot" />
                        <span class="point-text">
                          <strong>{p.title}</strong>
                          {p.detail && <span class="point-detail">{p.detail}</span>}
                        </span>
                        <span class="badge">
                          {p.category === "center" ? "Acopio" : "Personal"}
                        </span>
                      </button>
                    </li>
                  ))}
                </ul>
              </div>
            ))}
        </div>
      ))}
      <p id="list-empty" class="list-empty" hidden>No hay puntos con los filtros activos.</p>
      </div>
    </div>
  </div>
</section>

<script type="application/json" id="map-points-data" set:html={pointsJson}></script>

<script>
  import {
    parseQuake, filterQuakes, isRecent,
    formatRelativeTime, severityClass, VE_BBOX,
  } from "../lib/quakes";
  import { waLink, proWaMessage } from "../lib/phone";

  (function () {
    // Prefilled consultation message for "solo WhatsApp" professionals, with a
    // greeting for the viewer's local time.
    const proMsg = proWaMessage(new Date().getHours());
    const points = JSON.parse(
      document.getElementById("map-points-data")?.textContent || "[]",
    );
    function start() {
      if (typeof L === "undefined") return setTimeout(start, 100);
      const mapEl = document.getElementById("map");
      if (!mapEl || mapEl.dataset.ready) return;
      mapEl.dataset.ready = "1";

      const map = L.map(mapEl, { scrollWheelZoom: false }).setView([8, -66], 6);
      L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
        maxZoom: 19,
        attribution: "© OpenStreetMap",
      }).addTo(map);

      // Global location search (Nominatim) — fulfills the AID-01 search requirement.
      if (L.Control && L.Control.Geocoder) {
        L.Control.geocoder({ defaultMarkGeocode: true, placeholder: "Buscar lugar…" }).addTo(map);
      }

      const ICON = {
        center:
          '<path d="M12 6v12M6 12h12" stroke="#fff" stroke-width="2.4" stroke-linecap="round"/>',
        professional:
          '<path d="M16 19v-1.5a3.5 3.5 0 0 0-3.5-3.5h-1A3.5 3.5 0 0 0 8 17.5V19M12 11a3 3 0 1 0 0-6 3 3 0 0 0 0 6z" fill="none" stroke="#fff" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>',
        quake:
          '<path d="M4 12h3l2-5 3 10 2-5 1 2h5" fill="none" stroke="#3a2c00" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>',
        sos:
          '<path d="M12 4 2.5 20h19z M12 10v4 M12 17h.01" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>',
      };
      const COLOR = { center: "#2563eb", professional: "#dc2626", quake: "#eab308", sos: "#7c3aed" };
      // Color del marcador de incidente según severidad reportada.
      const SEV_COLOR = { rojo: "#d64533", amarillo: "#e8a33d", verde: "#2f7d32" };

      function pin(type, size, color) {
        const s = size || 30;
        return L.divIcon({
          className: "mk-wrap",
          iconSize: [s, s],
          iconAnchor: [s / 2, s / 2],
          popupAnchor: [0, -s / 2],
          html:
            '<span class="mk" style="background:' +
            (color || COLOR[type]) +
            ';width:' + s + 'px;height:' + s + 'px">' +
            '<svg viewBox="0 0 24 24">' + ICON[type] + "</svg></span>",
        });
      }

      const esc = (s) =>
        String(s).replace(/[&<>"]/g, (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;" })[c]);

      // One Leaflet layer per type so the legend can toggle each on/off.
      const layers = {
        center: L.layerGroup().addTo(map),
        professional: L.layerGroup().addTo(map),
        quake: L.layerGroup().addTo(map),
        sos: L.layerGroup().addTo(map),
      };

      // Humanitarian markers from the static metadata.
      const markers = {};
      const humMarkers = [];
      points.forEach((p) => {
        const m = L.marker([p.lat, p.lng], { icon: pin(p.category) });
        let html =
          '<strong class="pop-title">' + esc(p.title) + "</strong>";
        if (p.org) html += '<div class="pop-org">' + esc(p.org) + "</div>";
        if (p.detail) html += '<div class="pop-detail">' + esc(p.detail) + "</div>";
        if (p.needs && p.needs.length)
          html += '<div class="pop-needs"><b>Necesita:</b> ' + esc(p.needs.join(" · ")) + "</div>";
        // "Solo WhatsApp" professionals: link to WhatsApp (with the prefilled
        // message), never the call app. Otherwise keep the plain tel: link.
        const waOnly = p.category === "professional" && p.waOnly;
        const contactLink = (num) =>
          waOnly
            ? '<a href="' + esc(waLink(num, proMsg)) + '" target="_blank" rel="noopener noreferrer">WhatsApp: ' + esc(num) + "</a>"
            : '<a href="tel:' + esc(num.replace(/[^\d+]/g, "")) + '">' + esc(num) + "</a>";
        const mainNum = waOnly ? p.whatsapp || p.phone : p.phone;
        if (mainNum)
          html += '<div class="pop-phone">' + contactLink(mainNum) + "</div>";
        if (p.people && p.people.length) {
          html += '<div class="pop-people"><b>Contactos:</b>';
          p.people.forEach((pp) => {
            html +=
              '<div class="pop-person"><span>' + esc(pp.name) + "</span>" +
              contactLink(pp.contact) + "</div>";
          });
          html += "</div>";
        }
        m.bindPopup(html);
        layers[p.category].addLayer(m);
        markers[p.id] = m;
        humMarkers.push({ m: m, category: p.category, country: p.country, state: p.state });
      });

      // Side-list click pans to the marker.
      document.querySelectorAll(".point[data-id]").forEach((btn) => {
        btn.addEventListener("click", () => {
          const m = markers[btn.dataset.id];
          if (!m) return;
          map.setView(m.getLatLng(), 13, { animate: true });
          m.openPopup();
        });
      });

      // Legend = type filter. Toggling hides/shows that type on the map and
      // (for acopios/personal) in the side list.
      const active = { center: true, professional: true, quake: true, sos: true };
      const listItems = Array.prototype.slice.call(
        document.querySelectorAll("#map-list .point-item"),
      );

      // Hierarchical geo filter (Country -> State) over list AND markers.
      const geoCountrySel = document.getElementById("map-country");
      const geoStateSel = document.getElementById("map-state");
      function geoMatch(country, state) {
        const c = geoCountrySel ? geoCountrySel.value : "";
        const s = geoStateSel ? geoStateSel.value : "";
        return (!c || country === c) && (!s || state === s);
      }
      function applyGeo() {
        humMarkers.forEach((h) => {
          if (geoMatch(h.country, h.state)) layers[h.category].addLayer(h.m);
          else layers[h.category].removeLayer(h.m);
        });
      }
      function rebuildGeoStates() {
        if (!geoCountrySel || !geoStateSel) return;
        const c = geoCountrySel.value;
        const states = listItems
          .filter((li) => !c || li.dataset.country === c)
          .map((li) => li.dataset.state)
          .filter(Boolean);
        const uniq = [];
        states.forEach((s) => {
          if (uniq.indexOf(s) < 0) uniq.push(s);
        });
        uniq.sort((a, b) => a.localeCompare(b, "es"));
        const prev = geoStateSel.value;
        geoStateSel.innerHTML = '<option value="">Todos los estados</option>';
        uniq.forEach((s) => {
          const o = document.createElement("option");
          o.value = s;
          o.textContent = s;
          geoStateSel.appendChild(o);
        });
        geoStateSel.value = uniq.indexOf(prev) >= 0 ? prev : "";
      }

      function refreshList() {
        listItems.forEach((li) => {
          li.hidden = !(
            active[li.dataset.cat] && geoMatch(li.dataset.country, li.dataset.state)
          );
        });
        document.querySelectorAll("#map-list .state-block").forEach((g) => {
          g.hidden = !Array.prototype.some.call(
            g.querySelectorAll(".point-item"),
            (i) => !i.hidden,
          );
        });
        document.querySelectorAll("#map-list .country-block").forEach((g) => {
          g.hidden = !Array.prototype.some.call(
            g.querySelectorAll(".state-block"),
            (x) => !x.hidden,
          );
        });
        const empty = document.getElementById("list-empty");
        if (empty) empty.hidden = listItems.some((i) => !i.hidden);
      }
      document.querySelectorAll(".lg[data-type]").forEach((btn) => {
        btn.addEventListener("click", () => {
          const t = btn.dataset.type;
          active[t] = !active[t];
          btn.classList.toggle("active", active[t]);
          btn.setAttribute("aria-pressed", String(active[t]));
          if (active[t]) map.addLayer(layers[t]);
          else map.removeLayer(layers[t]);
          if (t === "center" || t === "professional") refreshList();
        });
      });

      // Country -> State cascade for the list/marker geo filter.
      if (geoCountrySel) {
        geoCountrySel.addEventListener("change", () => {
          rebuildGeoStates();
          applyGeo();
          refreshList();
        });
      }
      if (geoStateSel) {
        geoStateSel.addEventListener("change", () => {
          applyGeo();
          refreshList();
        });
      }
      rebuildGeoStates();

      // Reset button: recenter on Venezuela and turn all filters back on.
      function resetMap() {
        map.closePopup();
        map.setView([8, -66], 6);
        ["center", "professional", "quake", "sos"].forEach((t) => {
          if (!active[t]) {
            active[t] = true;
            map.addLayer(layers[t]);
          }
          const b = document.querySelector('.lg[data-type="' + t + '"]');
          if (b) {
            b.classList.add("active");
            b.setAttribute("aria-pressed", "true");
          }
        });
        if (geoCountrySel) geoCountrySel.value = "";
        if (geoStateSel) geoStateSel.value = "";
        rebuildGeoStates();
        applyGeo();
        refreshList();
      }
      document.getElementById("map-reset")?.addEventListener("click", resetMap);

      // Real-time earthquakes from USGS. We use the magnitude-filtered monthly
      // GeoJSON feed (CORS-enabled, no key) and clip to the Venezuela region.
      // Loaded lazily the first time the Mapa tab is opened so the ~1.4 MB
      // feed never downloads for users who don't open the map.
      const FEED =
        "https://earthquake.usgs.gov/earthquakes/feed/v1.0/summary/2.5_month.geojson";
      const qCountEl = document.getElementById("quake-count");
      const qBtn = document.getElementById("quake-refresh");
      const qErr = document.getElementById("quake-error");
      let quakesLoaded = false;

      // Sismos state (AID-014): parsed feed + per-id markers + in-memory filters
      // and the multi-select highlight set. All ephemeral (lost on reload).
      let quakesData = [];
      const quakeMarkers = {};
      const quakeFilter = { minMag: 2.5, dateRange: "month", depthBucket: "any" };
      const selectedQuakes = new Set();

      function makeQuakeMarker(q) {
        const size = Math.max(20, Math.min(40, 16 + (q.mag || 1) * 4));
        let html =
          '<strong class="pop-title">M ' + (q.mag ?? "?") + "</strong>" +
          '<div class="pop-detail">' + esc(q.place) + "</div>" +
          '<div class="pop-detail">' + esc(formatRelativeTime(q.time, Date.now())) + "</div>";
        if (q.url)
          html += '<div class="pop-phone"><a href="' + esc(q.url) +
            '" target="_blank" rel="noopener noreferrer">Ver en USGS ↗</a></div>';
        return L.marker([q.lat, q.lng], { icon: pin("quake", size) }).bindPopup(html);
      }

      // Turn the quake layer on (and sync the legend) without touching the others.
      function ensureQuakeLayer() {
        if (active.quake) return;
        active.quake = true;
        map.addLayer(layers.quake);
        const b = document.querySelector('.lg[data-type="quake"]');
        if (b) { b.classList.add("active"); b.setAttribute("aria-pressed", "true"); }
      }

      function updateClearSel() {
        const btn = document.getElementById("quake-clear");
        const n = document.getElementById("quake-seln");
        if (n) n.textContent = String(selectedQuakes.size);
        if (btn) btn.hidden = selectedQuakes.size === 0;
      }

      // Filter -> rebuild visible markers + the sidebar list. Re-applies the
      // highlight class because Leaflet recreates marker elements on re-add.
      function renderQuakes() {
        const now = Date.now();
        const filtered = filterQuakes(quakesData, quakeFilter, now);
        layers.quake.clearLayers();
        filtered.forEach((q) => {
          let m = quakeMarkers[q.id];
          if (!m) { m = makeQuakeMarker(q); quakeMarkers[q.id] = m; }
          layers.quake.addLayer(m);
          const el = m.getElement && m.getElement();
          if (el) el.classList.toggle("mk-sel", selectedQuakes.has(q.id));
        });
        renderQuakeList(filtered, now);
      }

      function renderQuakeList(filtered, now) {
        const listEl = document.getElementById("quake-list");
        const emptyEl = document.getElementById("quake-empty");
        const shownEl = document.getElementById("quake-shown");
        if (shownEl) shownEl.textContent = String(filtered.length);
        if (emptyEl) emptyEl.hidden = filtered.length > 0;
        if (!listEl) return;
        const sorted = filtered.slice().sort((a, b) => b.time - a.time);
        listEl.innerHTML = sorted.map((q) => {
          const mag = q.mag == null ? "?" : q.mag.toFixed(1);
          const sev = severityClass(q.mag);
          const when = formatRelativeTime(q.time, now);
          const depth = Math.round(q.depthKm);
          const sel = selectedQuakes.has(q.id);
          const fresh = isRecent(q.time, now) ? ' · <span class="qnew">🆕 nuevo</span>' : "";
          return (
            '<li class="quake-item ' + sev + (sel ? " sel" : "") + '" data-id="' + esc(q.id) + '">' +
              '<button type="button" class="quake-main" data-id="' + esc(q.id) + '">' +
                '<span class="qmag ' + sev + '">M' + esc(mag) + "</span>" +
                '<span class="qtext"><strong>' + esc(q.place || "Sismo") + "</strong>" +
                  '<span class="qmeta">' + esc(when) + " · " + depth + " km" + fresh + "</span>" +
                "</span>" +
                '<span class="qgo" aria-hidden="true">📍</span>' +
              "</button>" +
              '<div class="qactions">' +
                '<label class="qsel"><input type="checkbox" class="qcheck" data-id="' + esc(q.id) + '"' + (sel ? " checked" : "") + "> resaltar</label>" +
                '<button type="button" class="qbtn qcopy" data-coords="' + q.lat + ", " + q.lng + '">📋 coords</button>' +
                (q.url ? '<a class="qbtn qusgs" href="' + esc(q.url) + '" target="_blank" rel="noopener noreferrer">↗ USGS</a>' : "") +
              "</div>" +
            "</li>"
          );
        }).join("");
      }

      // `force` re-queries USGS on demand (refresh buttons); otherwise it's the
      // lazy first load. A cache-buster avoids a stale CDN copy.
      function loadQuakes(force) {
        if (quakesLoaded && !force) return;
        quakesLoaded = true;
        if (qBtn) qBtn.disabled = true;
        if (qErr) qErr.hidden = true;
        if (qCountEl) qCountEl.textContent = "…";
        const url = force ? FEED + "?t=" + Math.floor(Date.now() / 1000) : FEED;
        fetch(url)
          .then((r) => (r.ok ? r.json() : Promise.reject(r.status)))
          .then((data) => {
            quakesData = (data.features || [])
              .map((f) => parseQuake(f, VE_BBOX))
              .filter(Boolean);
            if (qCountEl) qCountEl.textContent = "(" + quakesData.length + ")";
            const stamp = document.getElementById("quake-updated");
            if (stamp) stamp.textContent = formatRelativeTime(Date.now(), Date.now());
            renderQuakes();
          })
          .catch(() => {
            if (qErr) qErr.hidden = false;
            if (qCountEl) qCountEl.textContent = "(0)";
            quakesData = [];
            renderQuakes();
          })
          .finally(() => {
            if (qBtn) qBtn.disabled = false;
          });
      }
      if (qBtn) qBtn.addEventListener("click", () => loadQuakes(true));
      document.getElementById("quake-refresh2")?.addEventListener("click", () => loadQuakes(true));

      // Sub-tab switch: Lugares (centers/professionals) <-> Sismos.
      document.querySelectorAll(".subtab[data-view]").forEach((btn) => {
        btn.addEventListener("click", () => {
          const v = btn.dataset.view;
          document.querySelectorAll(".subtab").forEach((b) => {
            const on = b === btn;
            b.classList.toggle("active", on);
            b.setAttribute("aria-selected", String(on));
          });
          const lug = document.getElementById("view-lugares");
          const sis = document.getElementById("view-sismos");
          if (lug) lug.hidden = v !== "lugares";
          if (sis) sis.hidden = v !== "sismos";
          if (v === "sismos") { ensureQuakeLayer(); loadQuakes(); renderQuakes(); }
        });
      });

      // Magnitude quick filters (single active minimum).
      document.querySelectorAll(".qmag-btn[data-min]").forEach((btn) => {
        btn.addEventListener("click", () => {
          quakeFilter.minMag = parseFloat(btn.dataset.min);
          document.querySelectorAll(".qmag-btn").forEach((b) => b.classList.toggle("active", b === btn));
          renderQuakes();
        });
      });
      document.getElementById("quake-date")?.addEventListener("change", (e) => {
        quakeFilter.dateRange = e.target.value;
        renderQuakes();
      });
      document.getElementById("quake-depth")?.addEventListener("change", (e) => {
        quakeFilter.depthBucket = e.target.value;
        renderQuakes();
      });
      document.getElementById("quake-clear")?.addEventListener("click", () => {
        selectedQuakes.clear();
        renderQuakes();
        updateClearSel();
      });

      // Delegated handlers for the (re-rendered) quake cards.
      const quakeListEl = document.getElementById("quake-list");
      if (quakeListEl) {
        quakeListEl.addEventListener("click", (ev) => {
          const main = ev.target.closest(".quake-main");
          if (main) {
            const m = quakeMarkers[main.dataset.id];
            if (m) { ensureQuakeLayer(); map.setView(m.getLatLng(), 9, { animate: true }); m.openPopup(); }
            return;
          }
          const copy = ev.target.closest(".qcopy");
          if (copy) {
            const txt = copy.dataset.coords;
            if (navigator.clipboard) navigator.clipboard.writeText(txt);
            const old = copy.textContent;
            copy.textContent = "✓ copiado";
            setTimeout(() => { copy.textContent = old; }, 1200);
          }
        });
        quakeListEl.addEventListener("change", (ev) => {
          const chk = ev.target.closest(".qcheck");
          if (!chk) return;
          const id = chk.dataset.id;
          if (chk.checked) selectedQuakes.add(id); else selectedQuakes.delete(id);
          const m = quakeMarkers[id];
          const el = m && m.getElement && m.getElement();
          if (el) el.classList.toggle("mk-sel", chk.checked);
          chk.closest(".quake-item")?.classList.toggle("sel", chk.checked);
          updateClearSel();
        });
      }

      // Incidentes reportados (SOS Venezuela 2026): colapsos, fugas, vías, etc.
      // Vía nuestro proxy cacheado. Solo los que traen coordenadas se pintan.
      const sosCountEl = document.getElementById("sos-count");
      let sosLoaded = false;
      const CAT_ES = {
        collapsed_building: "Edificio colapsado",
        gas_leak: "Fuga de gas",
        blocked_road: "Vía bloqueada",
        relief_center: "Centro de ayuda",
        fire: "Incendio",
        flood: "Inundación",
        medical: "Emergencia médica",
        missing_person: "Persona desaparecida",
      };
      const catLabel = (c) => CAT_ES[c] || String(c || "").replace(/_/g, " ");
      function loadReports() {
        if (sosLoaded) return;
        sosLoaded = true;
        if (sosCountEl) sosCountEl.textContent = "…";
        fetch("/api/sos/reports", { cache: "no-store" })
          .then((r) => (r.ok ? r.json() : Promise.reject(r.status)))
          .then((data) => {
            const reports = Array.isArray(data.reports) ? data.reports : [];
            layers.sos.clearLayers();
            let plotted = 0;
            reports.forEach((rp) => {
              // Los centros de acopio (aid_point) ya están en nuestra DB y se
              // pintan como acopios; aquí solo van incidentes reales.
              if (rp.category === "aid_point") return;
              const lat = rp.lat_pub, lng = rp.lng_pub;
              if (!Number.isFinite(lat) || !Number.isFinite(lng)) return;
              plotted++;
              const color = SEV_COLOR[rp.severity] || COLOR.sos;
              const place = [rp.parroquia, rp.municipio].filter(Boolean).join(" · ");
              let html = '<strong class="pop-title">' + esc(rp.title || catLabel(rp.category)) + "</strong>";
              html += '<div class="pop-org">' + esc(catLabel(rp.category)) + "</div>";
              if (place) html += '<div class="pop-detail">' + esc(place) + "</div>";
              if (rp.people_trapped_count)
                html += '<div class="pop-needs"><b>Personas atrapadas:</b> ' + esc(rp.people_trapped_count) + "</div>";
              if (rp.description) {
                const d = String(rp.description);
                html += '<div class="pop-detail">' + esc(d.length > 220 ? d.slice(0, 220) + "…" : d) + "</div>";
              }
              if (rp.source_url)
                html += '<div class="pop-phone"><a href="' + esc(rp.source_url) + '" target="_blank" rel="noopener noreferrer">Ver fuente ↗</a></div>';
              const m = L.marker([lat, lng], { icon: pin("sos", 28, color) }).bindPopup(html);
              layers.sos.addLayer(m);
            });
            if (sosCountEl) sosCountEl.textContent = "(" + plotted + ")";
          })
          .catch(() => {
            if (sosCountEl) sosCountEl.textContent = "(0)";
          });
      }

      // When the Mapa tab becomes visible (it starts hidden): fix the map size
      // and lazily load the earthquakes. Fired by sidebar tabs, dashboard cards
      // and hash deep-links alike via the shared "tabchange" event.
      document.addEventListener("tabchange", (e) => {
        if (e.detail === "mapa")
          setTimeout(() => {
            map.invalidateSize();
            loadQuakes();
            loadReports();
          }, 60);
      });

      // If the Mapa tab is already the active one on load, load immediately.
      if (mapEl.closest(".tab-panel")?.classList.contains("active")) {
        loadQuakes();
        loadReports();
      }
    }
    if (document.readyState === "loading")
      document.addEventListener("DOMContentLoaded", start);
    else start();
  })();
</script>

