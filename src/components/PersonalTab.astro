---
import type { ImageEntry } from "../types";
import { waLink } from "../lib/phone";

interface Props {
  professionals: ImageEntry[];
}

const { professionals } = Astro.props;

interface Listing {
  name: string;
  specialty?: string;
  organization?: string;
  registry?: string;
  description?: string;
  location: string;
  state: string;
  area: string;
  phone?: string;
  whatsapp?: string;
  whatsappOnly?: boolean;
  instagram?: string;
  website?: string;
  notes?: string;
}

const locationLabel = (e: ImageEntry) =>
  [e.location.city, e.location.state, e.location.country].filter(Boolean).join(", ");

// "Area" = sector, derived from the specialty (medical, mental health, etc.).
const areaOf = (specialty?: string) => {
  const s = (specialty || "").toLowerCase();
  if (/psicolog/.test(s)) return "Salud mental";
  if (/cirug|enfermer|m[eé]dic|pediatr|salud|odont|trauma|farmac/.test(s)) return "Médica";
  if (/log[ií]stic|transport|distribu/.test(s)) return "Logística";
  if (/educa|docen|escuela/.test(s)) return "Educación";
  return "General";
};

const listings: Listing[] = [];
for (const e of professionals) {
  const location = locationLabel(e);
  const state = e.location.state || "Sin especificar";
  const area = areaOf(e.specialty);
  if (e.people && e.people.length > 0) {
    const single = e.people.length === 1;
    for (const p of e.people) {
      listings.push({
        name: p.name,
        specialty: p.specialty || e.specialty,
        organization: e.organization,
        registry: p.registry,
        description: single ? e.description : undefined,
        location,
        state,
        area: areaOf(p.specialty || e.specialty),
        phone: p.contact,
        whatsapp: single ? e.contact?.whatsapp : undefined,
        whatsappOnly: e.contact?.whatsappOnly,
        instagram: single ? e.contact?.instagram : undefined,
        website: single ? e.contact?.website : undefined,
      });
    }
  } else {
    listings.push({
      name: e.title,
      specialty: e.specialty,
      organization: e.organization,
      description: e.description,
      location,
      state,
      area,
      phone: e.contact?.phone,
      whatsapp: e.contact?.whatsapp,
      whatsappOnly: e.contact?.whatsappOnly,
      instagram: e.contact?.instagram,
      website: e.contact?.website,
      notes: e.notes,
    });
  }
}

// Data-driven filter options.
const stateOptions = [...new Set(listings.map((l) => l.state))].sort();
const professionOptions = [
  ...new Set(listings.map((l) => l.specialty).filter(Boolean)),
].sort() as string[];
const areaOptions = [...new Set(listings.map((l) => l.area))].sort();

const telHref = (phone: string) => `tel:${phone.replace(/[^\d+]/g, "")}`;
const waHref = (n: string) => {
  // If the number already carries an international code ("+52 …"), respect it —
  // don't assume Venezuela. Only bare/local numbers get the +58 default.
  if (n.trim().startsWith("+")) return `https://wa.me/${n.replace(/\D/g, "")}`;
  let d = n.replace(/\D/g, "");
  if (d.startsWith("58")) {
    /* ya trae el código de Venezuela */
  } else if (d.startsWith("0")) d = "58" + d.slice(1); // 0412… → 58412…
  else d = "58" + d; // número local venezolano
  return `https://wa.me/${d}`;
};
const igHref = (h: string) => `https://instagram.com/${h.replace(/^@/, "").trim()}`;
const webHref = (w: string) => (/^https?:\/\//.test(w) ? w : `https://${w}`);
---

<section id="tab-personal" class="tab-panel">
  <header class="panel-head">
    <p class="panel-eyebrow">Ayuda profesional</p>
    <h2 class="panel-title">Quién ofrece ayuda</h2>
    <p class="panel-intro">
      {listings.length} profesionales y servicios voluntarios. Filtra por estado,
      profesión o área, y toca cada uno para ver cómo contactarlo.
    </p>
  </header>

  <form class="filters" aria-label="Filtros de personal">
    <div class="f-field">
      <label for="pe-state">Estado</label>
      <select id="pe-state">
        <option value="">Todos</option>
        {stateOptions.map((s) => <option value={s}>{s}</option>)}
      </select>
    </div>
    <div class="f-field">
      <label for="pe-prof">Profesión</label>
      <select id="pe-prof">
        <option value="">Todas</option>
        {professionOptions.map((p) => <option value={p}>{p}</option>)}
      </select>
    </div>
    <div class="f-field">
      <label for="pe-area">Área</label>
      <select id="pe-area">
        <option value="">Todas</option>
        {areaOptions.map((a) => <option value={a}>{a}</option>)}
      </select>
    </div>
    <button type="button" id="pe-reset" class="f-reset">Limpiar</button>
  </form>

  <p class="result-line"><span id="pe-count">{listings.length}</span> profesionales</p>
  <p id="pe-empty" class="empty-msg" hidden>
    Nadie coincide con los filtros. Prueba quitar alguno.
  </p>

  <ul class="prof-list">
    {
      listings.map((l) => {
        // "Solo WhatsApp": the number opens WhatsApp only (no call link), and
        // the WhatsApp number falls back to the phone if no separate one given.
        const waNumber = l.whatsappOnly ? l.whatsapp || l.phone : l.whatsapp;
        const showTel = l.phone && !l.whatsappOnly;
        return (
        <li
          class="prof-item"
          data-state={l.state}
          data-profession={l.specialty ?? ""}
          data-area={l.area}
        >
          <details>
            <summary>
              <span class="summary-main">
                <span class="prof-name">{l.name}</span>
                {l.specialty && <span class="prof-specialty">{l.specialty}</span>}
              </span>
              <span class="chevron" aria-hidden="true">▾</span>
            </summary>

            <div class="prof-body">
              {l.organization && <p class="prof-org">{l.organization}</p>}
              {l.description && <p class="prof-desc">{l.description}</p>}

              <dl class="prof-data">
                {l.registry && (
                  <>
                    <dt>Registro</dt>
                    <dd>{l.registry}</dd>
                  </>
                )}
                {l.area && (
                  <>
                    <dt>Área</dt>
                    <dd>{l.area}</dd>
                  </>
                )}
                {l.location && (
                  <>
                    <dt>Ubicación</dt>
                    <dd>{l.location}</dd>
                  </>
                )}
                {showTel && (
                  <>
                    <dt>Teléfono</dt>
                    <dd>
                      <a href={telHref(l.phone!)}>{l.phone}</a>
                    </dd>
                  </>
                )}
                {waNumber && (
                  <>
                    <dt>WhatsApp</dt>
                    <dd>
                      <a
                        href={l.whatsappOnly ? waLink(waNumber) : waHref(waNumber)}
                        target="_blank"
                        rel="noopener noreferrer"
                        data-wa-pro={l.whatsappOnly ? waNumber : undefined}
                      >
                        {waNumber}
                      </a>
                    </dd>
                  </>
                )}
                {l.instagram && (
                  <>
                    <dt>Instagram</dt>
                    <dd>
                      <a href={igHref(l.instagram)} target="_blank" rel="noopener noreferrer">
                        {l.instagram}
                      </a>
                    </dd>
                  </>
                )}
                {l.website && (
                  <>
                    <dt>Sitio web</dt>
                    <dd>
                      <a href={webHref(l.website)} target="_blank" rel="noopener noreferrer">
                        {l.website}
                      </a>
                    </dd>
                  </>
                )}
              </dl>

              {l.notes && <p class="prof-note">{l.notes}</p>}
            </div>
          </details>
        </li>
        );
      })
    }
  </ul>
</section>

<script>
  import { waLink, proWaMessage } from "../lib/phone";

  // "Solo WhatsApp" links: fill in the consultation message with a greeting for
  // the viewer's local time (done client-side so the greeting is accurate).
  const hour = new Date().getHours();
  const msg = proWaMessage(hour);
  document.querySelectorAll<HTMLAnchorElement>("a[data-wa-pro]").forEach((a) => {
    a.href = waLink(a.dataset.waPro || "", msg);
  });

  const root = document.getElementById("tab-personal");
  if (root) {
    const items = [...root.querySelectorAll<HTMLElement>(".prof-item")];
    const stateSel = root.querySelector<HTMLSelectElement>("#pe-state")!;
    const profSel = root.querySelector<HTMLSelectElement>("#pe-prof")!;
    const areaSel = root.querySelector<HTMLSelectElement>("#pe-area")!;
    const countEl = root.querySelector("#pe-count")!;
    const emptyEl = root.querySelector<HTMLElement>("#pe-empty")!;

    function apply() {
      const st = stateSel.value;
      const pr = profSel.value;
      const ar = areaSel.value;
      for (const it of items) {
        it.hidden = !(
          (!st || it.dataset.state === st) &&
          (!pr || it.dataset.profession === pr) &&
          (!ar || it.dataset.area === ar)
        );
      }
      const total = items.filter((i) => !i.hidden).length;
      countEl.textContent = String(total);
      emptyEl.hidden = total > 0;
    }

    [stateSel, profSel, areaSel].forEach((el) => el.addEventListener("change", apply));
    root.querySelector("#pe-reset")?.addEventListener("click", () => {
      stateSel.value = "";
      profSel.value = "";
      areaSel.value = "";
      apply();
    });
  }
</script>

<style>
  .tab-panel { display: none; }
  .tab-panel.active { display: block; }

  /* ---- Filters (shared visual language with Acopios) ---- */
  .filters {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    gap: 12px;
    padding: 16px;
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: 12px;
    margin-bottom: 16px;
  }
  .f-field { display: flex; flex-direction: column; gap: 4px; }
  .f-field label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .f-field select {
    font-family: var(--font-body);
    font-size: 13px;
    padding: 8px 10px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--paper);
    color: var(--text);
    min-width: 160px;
  }
  .f-field select:focus { outline: none; border-color: var(--gold); }
  .f-reset {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 13px;
    padding: 9px 14px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: transparent;
    color: var(--ink);
    cursor: pointer;
  }
  .f-reset:hover { border-color: var(--ink); }

  .result-line { font-family: var(--font-mono); font-size: 12px; color: var(--muted); margin: 0 0 18px; }
  #pe-count { color: var(--ink); font-weight: 700; }
  .empty-msg {
    font-size: 14px;
    color: var(--muted);
    background: var(--card);
    border: 1px dashed var(--line);
    border-radius: 10px;
    padding: 20px;
    text-align: center;
    max-width: 720px;
  }

  /* ---- List ---- */
  .prof-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
    max-width: 720px;
  }

  details {
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: 12px;
    overflow: hidden;
    transition: border-color 0.18s, box-shadow 0.18s;
  }
  details[open] { border-color: #d3d8e2; box-shadow: 0 8px 24px rgba(20, 33, 61, 0.07); }

  summary {
    list-style: none;
    cursor: pointer;
    padding: 15px 18px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    user-select: none;
  }
  summary::-webkit-details-marker { display: none; }
  summary:hover { background: #fafbfc; }

  .summary-main { display: flex; flex-direction: column; gap: 3px; min-width: 0; }
  .prof-name { font-family: var(--font-display); font-size: 15px; font-weight: 700; color: var(--ink); }
  .prof-specialty { font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.04em; color: var(--gold-deep); }

  .chevron { color: var(--muted); font-size: 13px; transition: transform 0.2s; flex-shrink: 0; }
  details[open] .chevron { transform: rotate(180deg); }

  .prof-body {
    padding: 4px 18px 18px;
    border-top: 1px solid var(--line);
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .prof-org { font-size: 13px; font-weight: 600; color: var(--gold-deep); margin: 12px 0 0; }
  .prof-desc { font-size: 13.5px; line-height: 1.5; margin: 0; color: var(--text); }

  .prof-data {
    display: grid;
    grid-template-columns: max-content 1fr;
    gap: 6px 18px;
    margin: 6px 0 0;
    font-size: 13.5px;
  }
  .prof-data dt {
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--muted);
    padding-top: 2px;
  }
  .prof-data dd { margin: 0; color: var(--text); }
  .prof-data a {
    font-family: var(--font-mono);
    color: var(--ink-soft);
    text-decoration: none;
    font-weight: 700;
    border-bottom: 1px solid var(--gold);
  }
  .prof-data a:hover { color: var(--gold-deep); }

  .prof-note { font-size: 12px; color: var(--muted); font-style: italic; margin: 4px 0 0; }
</style>
