---
// AID-08: directory of online services to find / report missing persons.
// Easy to maintain — add or remove an entry here and it appears in the UI.
const services = [
  {
    url: "https://reportaven.com",
    name: "ReportaVen",
    host: "reportaven.com",
    desc: "Reporta y busca personas afectadas durante la emergencia.",
  },
  {
    url: "https://redayudavenezuela.com",
    name: "Red Ayuda Venezuela",
    host: "redayudavenezuela.com",
    desc: "Red que conecta solicitudes de ayuda con voluntarios y recursos.",
  },
  {
    url: "https://terremoto.hazlohoy.org/",
    name: "Terremoto · Hazlo Hoy",
    host: "terremoto.hazlohoy.org",
    desc: "Reporte y búsqueda de personas tras el terremoto.",
  },
  {
    url: "https://desaparecidosterremotovenezuela.com/",
    name: "Desaparecidos Terremoto Venezuela",
    host: "desaparecidosterremotovenezuela.com",
    desc: "Registro y búsqueda de personas desaparecidas.",
  },
];
---

<section id="tab-servicios" class="tab-panel">
  <header class="panel-head">
    <p class="panel-eyebrow">Personas desaparecidas</p>
    <h2 class="panel-title">Servicios de búsqueda</h2>
    <p class="panel-intro">
      Plataformas en línea para buscar, reportar o localizar personas durante la
      emergencia. Cada enlace abre el servicio en una pestaña nueva.
    </p>
  </header>

  <ul class="svc-list">
    {
      services.map((s) => (
        <li>
          <a class="svc" href={s.url} target="_blank" rel="noopener noreferrer">
            <span class="svc-main">
              <span class="svc-name">{s.name}</span>
              <span class="svc-desc">{s.desc}</span>
              <span class="svc-host">{s.host}</span>
            </span>
            <span class="svc-go" aria-hidden="true">↗</span>
          </a>
        </li>
      ))
    }
  </ul>

  <p class="svc-note">
    Estos servicios son operados por terceros. Verifica la información en la
    fuente original antes de actuar.
  </p>
</section>

<style>
  .tab-panel { display: none; }
  .tab-panel.active { display: block; }

  .svc-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
    max-width: 640px;
  }

  .svc {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 18px 20px;
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: 12px;
    text-decoration: none;
    transition: border-color 0.18s, box-shadow 0.18s, transform 0.18s;
  }
  .svc:hover {
    border-color: #d3d8e2;
    box-shadow: 0 8px 24px rgba(20, 33, 61, 0.08);
    transform: translateY(-2px);
  }

  .svc-main { display: flex; flex-direction: column; gap: 4px; min-width: 0; }
  .svc-name {
    font-family: var(--font-display);
    font-size: 16px;
    font-weight: 700;
    color: var(--ink);
  }
  .svc-desc { font-size: 13px; color: var(--text); line-height: 1.4; }
  .svc-host { font-family: var(--font-mono); font-size: 11px; color: var(--gold-deep); }

  .svc-go {
    font-family: var(--font-mono);
    font-size: 18px;
    color: var(--gold-deep);
    flex-shrink: 0;
  }

  .svc-note {
    font-size: 12px;
    color: var(--muted);
    font-style: italic;
    margin: 20px 0 0;
    max-width: 640px;
  }

</style>
