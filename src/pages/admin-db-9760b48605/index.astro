---
// AID-09: hidden admin CRUD. On-demand (not prerendered), at an unguessable
// URL, guarded by session-cookie login (admin role). NOT linked anywhere in the site.
export const prerender = false;

import { getEntries, dbAvailable } from "../../lib/db";

const ready = dbAvailable();
const entries = ready ? await getEntries() : [];
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Admin · Ayuda Venezuela</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Archivo:wght@600;700;800&family=Public+Sans:wght@400;500;600;700&family=Space+Mono:wght@400;700&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet-control-geocoder@2.4.0/dist/Control.Geocoder.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="https://unpkg.com/leaflet-control-geocoder@2.4.0/dist/Control.Geocoder.js"></script>
  </head>
  <body>
    <div class="warn">
      ⚠️ Página de administración — manéjala con cuidado. Los cambios afectan la
      base de datos en vivo.
    </div>

    <header class="bar">
      <h1>Admin · Ayuda Venezuela</h1>
      <button id="copy-url" type="button" class="btn ghost">
        <svg viewBox="0 0 24 24" aria-hidden="true"><rect x="9" y="9" width="11" height="11" rx="2" /><path d="M5 15V5a2 2 0 0 1 2-2h10" /></svg>
        Copiar URL
      </button>
    </header>

    <nav class="tabs" aria-label="Vistas">
      <button class="tab active" type="button" data-view="registros">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 6h16M4 12h16M4 18h10" /></svg>
        Registros
      </button>
      <button class="tab" type="button" data-view="auditoria">
        <svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="9" /><path d="M12 7v5l3 2" /></svg>
        Auditoría
      </button>
      <button class="tab" type="button" data-view="pendientes">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M9 11l3 3L22 4M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
        Pendientes <span id="pend-count" class="tab-badge" hidden>0</span>
      </button>
      <button class="tab" type="button" data-view="usuarios">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2M9 7a4 4 0 1 0 0 .01M23 21v-2a4 4 0 0 0-3-3.87"/></svg>
        Usuarios
      </button>
    </nav>

    {
      !ready && (
        <p class="nodb">
          La base de datos no está configurada (falta <code>DATABASE_URL</code>). Configúrala para administrar registros.
        </p>
      )
    }

    <section id="view-registros" class="view active">
      <div class="reg-layout">
        <aside class="sidebar" id="filters-sidebar">
          <div class="sidebar-head">
            <h2>Filtros</h2>
            <button type="button" id="f-clear" class="btn ghost">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M18 6 6 18M6 6l12 12" /></svg>
              Limpiar
            </button>
          </div>
          <div class="filters">
            <label>Búsqueda
              <input id="search" type="search" placeholder="Título, organización…" />
            </label>
            <label>Tipo
              <select id="f-category">
                <option value="">Todos</option>
                <option value="center">Centro</option>
                <option value="professional">Profesional</option>
              </select>
            </label>
            <label>País
              <select id="f-country"><option value="">Todos</option></select>
            </label>
            <label>Estado
              <select id="f-state"><option value="">Todos</option></select>
            </label>
            <label>Urgencia
              <select id="f-urgency">
                <option value="">Todas</option>
                <option value="high">Alta</option>
                <option value="medium">Media</option>
                <option value="low">Baja</option>
              </select>
            </label>
            <label>Organización
              <select id="f-org"><option value="">Todas</option></select>
            </label>
          </div>
        </aside>

        <div class="main-col">
          <div class="view-tools">
            <div class="vt-left">
              <button id="filters-toggle" type="button" class="btn ghost" aria-expanded="true" aria-controls="filters-sidebar">
                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 5h18l-7 8v5l-4 2v-7z" /></svg>
                Filtros
              </button>
              <p class="count">
                <span id="count">{entries.length}</span> registros ·
                <span id="count-c">0</span> centros ·
                <span id="count-p">0</span> profesionales
              </p>
            </div>
            <button id="new-btn" type="button" class="btn primary">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 5v14M5 12h14" /></svg>
              Nuevo
            </button>
          </div>

          <div class="table-wrap">
          <table>
      <thead>
        <tr><th>Título</th><th>Organización</th><th>Tipo</th><th>Estado</th><th>Urgencia</th><th></th></tr>
      </thead>
      <tbody id="rows">
        {
          entries.map((e) => (
            <tr
              data-filename={e.filename}
              data-cat={e.category}
              data-country={e.location?.country ?? ""}
              data-state={e.location?.state ?? ""}
              data-urg={e.urgency ?? ""}
              data-org={e.organization ?? ""}
            >
              <td>{e.title}</td>
              <td>{e.organization ?? "—"}</td>
              <td>{e.category === "center" ? "Centro" : "Profesional"}</td>
              <td>{e.location?.state || "—"}</td>
              <td>{{ high: "Alta", medium: "Media", low: "Baja" }[e.urgency ?? ""] ?? "—"}</td>
              <td class="actions">
                <button type="button" class="edit" data-filename={e.filename}>Editar</button>
                <button type="button" class="del" data-filename={e.filename}>Borrar</button>
              </td>
            </tr>
          ))
        }
      </tbody>
    </table>
          </div>
    <nav class="pager" id="pager" hidden>
      <button type="button" id="pg-prev" class="btn ghost">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M15 18l-6-6 6-6" /></svg>
        Anterior
      </button>
      <span id="pg-info"></span>
      <button type="button" id="pg-next" class="btn ghost">
        Siguiente
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M9 18l6-6-6-6" /></svg>
      </button>
    </nav>
        </div>
      </div>
    </section>

    <section id="view-auditoria" class="view">
      <div class="view-tools">
        <p class="audit-note">Quién guardó qué y desde dónde (IP, país, navegador). No hay cuentas de usuario, así que el origen identifica la sesión.</p>
        <button type="button" id="audit-refresh" class="btn ghost">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 12a9 9 0 0 1 15-6.7L21 8M21 3v5h-5M21 12a9 9 0 0 1-15 6.7L3 16M3 21v-5h5" /></svg>
          Actualizar
        </button>
      </div>
      <div class="audit-wrap">
        <table class="audit-table">
          <thead>
            <tr><th>Fecha</th><th>Acción</th><th>Registro</th><th>IP</th><th>País</th><th>Navegador</th></tr>
          </thead>
          <tbody id="audit-rows"><tr><td colspan="6">—</td></tr></tbody>
        </table>
      </div>
    </section>

    <section id="view-pendientes" class="view">
      <div class="view-tools"><p class="audit-note">Sugerencias enviadas por usuarios. Aprobar crea el registro; rechazar lo descarta.</p>
        <button type="button" id="pend-refresh" class="btn ghost">Actualizar</button></div>
      <div class="audit-wrap"><table class="audit-table">
        <thead><tr><th>Fecha</th><th>De</th><th>Tipo</th><th>Título</th><th>Estado/Ciudad</th><th></th></tr></thead>
        <tbody id="pend-rows"><tr><td colspan="6">—</td></tr></tbody>
      </table></div>
    </section>
    <section id="view-usuarios" class="view">
      <div class="view-tools"><p class="audit-note">Cuentas registradas. Puedes nombrar o quitar administradores.</p>
        <button type="button" id="users-refresh" class="btn ghost">Actualizar</button></div>
      <div class="audit-wrap"><table class="audit-table">
        <thead><tr><th>Apodo</th><th>Rol</th><th>Creado</th><th></th></tr></thead>
        <tbody id="users-rows"><tr><td colspan="4">—</td></tr></tbody>
      </table></div>
    </section>

    <!-- Editor -->
    <dialog id="editor">
      <form id="form" method="dialog">
        <h2 id="form-title">Nuevo registro</h2>
        <div class="grid">
          <label>Categoría
            <select name="category">
              <option value="center">Centro</option>
              <option value="professional">Profesional</option>
            </select>
          </label>
          <label>Urgencia
            <select name="urgency">
              <option value="">—</option>
              <option value="high">Alta</option>
              <option value="medium">Media</option>
              <option value="low">Baja</option>
            </select>
          </label>
          <label class="wide">Título * <input name="title" required /></label>
          <label class="wide">Organización <input name="organization" /></label>
          <label>Especialidad <input name="specialty" /></label>
          <label>País <input name="country" value="Venezuela" /></label>
          <label>Estado <input name="state" /></label>
          <label>Ciudad <input name="city" /></label>
          <label class="wide">Dirección <input name="address" /></label>
          <div class="wide map-pick">
            <span class="map-pick-label">Ubicación — busca o haz clic en el mapa para fijar las coordenadas (también puedes arrastrar el marcador)</span>
            <div id="pick-map"></div>
          </div>
          <label>Latitud <input name="lat" type="number" step="any" /></label>
          <label>Longitud <input name="lng" type="number" step="any" /></label>
          <label class="wide">Horario <input name="schedule" /></label>
          <label class="wide">Descripción <textarea name="description" rows="2"></textarea></label>
          <label class="wide">Necesidades (una por línea) <textarea name="needs" rows="3"></textarea></label>
          <label class="check"><input type="checkbox" name="acceptsMonetary" /> Acepta donación monetaria</label>
          <fieldset class="wide">
            <legend>Contacto</legend>
            <div class="grid">
              <label>Teléfono <input name="c_phone" /></label>
              <label>WhatsApp <input name="c_whatsapp" /></label>
              <label>Instagram <input name="c_instagram" /></label>
              <label>Web <input name="c_website" /></label>
              <label>Correo <input name="c_email" /></label>
            </div>
          </fieldset>
          <fieldset class="wide repeat">
            <legend>Personas</legend>
            <div id="people-list" class="rrows"></div>
            <button type="button" class="btn ghost add-row" data-add="person">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 5v14M5 12h14" /></svg>
              Agregar persona
            </button>
          </fieldset>
          <fieldset class="wide repeat">
            <legend>Puntos de recolección</legend>
            <div id="cp-list" class="rrows"></div>
            <button type="button" class="btn ghost add-row" data-add="cp">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 5v14M5 12h14" /></svg>
              Agregar punto
            </button>
          </fieldset>
          <label class="wide">Notas <textarea name="notes" rows="2"></textarea></label>
          <label>Origen <input name="source" /></label>
        </div>
        <p class="form-status" id="form-status"></p>
        <div class="form-actions">
          <button type="button" id="cancel" class="btn ghost">Cancelar</button>
          <button type="button" id="save" class="btn primary">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M20 6 9 17l-5-5" /></svg>
            Guardar
          </button>
        </div>
      </form>
    </dialog>

    <script is:inline define:vars={{ ENTRIES: entries }}>
      const slug = (s) => (s || "").toLowerCase().normalize("NFD")
        .replace(/[̀-ͯ]/g, "").replace(/[^a-z0-9]+/g, "-")
        .replace(/^-+|-+$/g, "").slice(0, 40);
      let byName = Object.fromEntries(ENTRIES.map((e) => [e.filename, e]));
      const dlg = document.getElementById("editor");
      const form = document.getElementById("form");
      const statusEl = document.getElementById("form-status");
      let mode = "create";
      let editingName = null;

      const setv = (n, v) => { const el = form.elements[n]; if (el) el.value = v ?? ""; };

      // ---- Mapa selector de coordenadas en el modal ----
      let pickMap, pickMarker;
      const round6 = (n) => Math.round(n * 1e6) / 1e6;
      function writeLatLng(lat, lng) {
        form.elements.lat.value = round6(lat);
        form.elements.lng.value = round6(lng);
      }
      function setMarker(lat, lng) {
        if (!pickMap) return;
        if (!pickMarker) {
          pickMarker = L.marker([lat, lng], { draggable: true }).addTo(pickMap);
          pickMarker.on("dragend", () => {
            const p = pickMarker.getLatLng();
            writeLatLng(p.lat, p.lng);
          });
        } else pickMarker.setLatLng([lat, lng]);
        writeLatLng(lat, lng);
      }
      function clearMarker() {
        if (pickMap && pickMarker) { pickMap.removeLayer(pickMarker); pickMarker = null; }
      }
      function initPickMap() {
        if (pickMap || typeof L === "undefined") return;
        pickMap = L.map("pick-map", { scrollWheelZoom: false }).setView([8, -66], 5);
        L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
          maxZoom: 19, attribution: "© OpenStreetMap",
        }).addTo(pickMap);
        if (L.Control && L.Control.Geocoder) {
          L.Control.geocoder({ defaultMarkGeocode: false, placeholder: "Buscar lugar…" })
            .on("markgeocode", (e) => {
              const c = e.geocode.center;
              setMarker(c.lat, c.lng);
              pickMap.setView(c, 15);
            })
            .addTo(pickMap);
        }
        pickMap.on("click", (e) => setMarker(e.latlng.lat, e.latlng.lng));
      }
      function syncMap() {
        initPickMap();
        if (!pickMap) return;
        setTimeout(() => {
          pickMap.invalidateSize();
          const lat = parseFloat(form.elements.lat.value);
          const lng = parseFloat(form.elements.lng.value);
          if (Number.isFinite(lat) && Number.isFinite(lng)) {
            setMarker(lat, lng);
            pickMap.setView([lat, lng], 13);
          } else {
            clearMarker();
            pickMap.setView([8, -66], 5);
          }
        }, 90);
      }

      // ---- Personas / Puntos de recolección: filas repetibles (no JSON) ----
      const PERSON_FIELDS = [
        { k: "name", ph: "Nombre" },
        { k: "specialty", ph: "Especialidad" },
        { k: "registry", ph: "Registro" },
        { k: "contact", ph: "Contacto (tel., correo…)" },
      ];
      const CP_FIELDS = [
        { k: "state", ph: "Estado" },
        { k: "location", ph: "Ubicación / dirección" },
      ];
      const TRASH_SVG = '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 6h18M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2m2 0v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6"/></svg>';
      function repeatRow(fields, data) {
        const row = document.createElement("div");
        row.className = "rrow";
        for (const f of fields) {
          const inp = document.createElement("input");
          inp.placeholder = f.ph;
          inp.dataset.k = f.k;
          inp.value = (data && data[f.k]) || "";
          row.appendChild(inp);
        }
        const del = document.createElement("button");
        del.type = "button";
        del.className = "icon-btn danger row-del";
        del.title = "Quitar";
        del.setAttribute("aria-label", "Quitar");
        del.innerHTML = TRASH_SVG;
        row.appendChild(del);
        return row;
      }
      function addPerson(p) { document.getElementById("people-list").appendChild(repeatRow(PERSON_FIELDS, p)); }
      function addCp(c) { document.getElementById("cp-list").appendChild(repeatRow(CP_FIELDS, c)); }
      function setRepeats(entry) {
        document.getElementById("people-list").innerHTML = "";
        document.getElementById("cp-list").innerHTML = "";
        (entry?.people || []).forEach(addPerson);
        (entry?.collectionPoints || []).forEach(addCp);
      }
      function readRepeat(listId, fields, required) {
        return [...document.querySelectorAll("#" + listId + " .rrow")]
          .map((row) => {
            const obj = {};
            for (const f of fields) {
              const v = row.querySelector('[data-k="' + f.k + '"]').value.trim();
              if (v) obj[f.k] = v;
            }
            return obj;
          })
          .filter((o) => o[required]);
      }

      function openForm(entry) {
        form.reset();
        statusEl.textContent = "";
        if (entry) {
          mode = "edit"; editingName = entry.filename;
          document.getElementById("form-title").textContent = "Editar: " + (entry.title || entry.filename);
          setv("category", entry.category); setv("urgency", entry.urgency);
          setv("title", entry.title); setv("organization", entry.organization);
          setv("specialty", entry.specialty); setv("description", entry.description);
          setv("country", entry.location?.country); setv("state", entry.location?.state);
          setv("city", entry.location?.city); setv("address", entry.location?.address);
          setv("lat", entry.coords?.lat); setv("lng", entry.coords?.lng);
          setv("schedule", entry.schedule); setv("notes", entry.notes); setv("source", entry.source);
          setv("needs", (entry.needs || []).join("\n"));
          form.elements.acceptsMonetary.checked = !!entry.acceptsMonetary;
          const c = entry.contact || {};
          ["phone","whatsapp","instagram","website","email"].forEach((k) => setv("c_" + k, c[k]));
        } else {
          mode = "create"; editingName = null;
          document.getElementById("form-title").textContent = "Nuevo registro";
        }
        setRepeats(entry);
        dlg.showModal();
        syncMap();
      }

      function collect() {
        const g = (n) => (form.elements[n]?.value ?? "").trim();
        const num = (n) => { const v = g(n); return v === "" ? null : parseFloat(v); };
        const e = {
          filename: g("filename"), category: g("category"), title: g("title"),
          urgency: g("urgency") || undefined,
          organization: g("organization") || undefined,
          specialty: g("specialty") || undefined,
          description: g("description") || undefined,
          location: { country: g("country"), state: g("state"), city: g("city"), address: g("address") || undefined },
          schedule: g("schedule") || undefined,
          needs: g("needs").split("\n").map((s) => s.trim()).filter(Boolean),
          acceptsMonetary: form.elements.acceptsMonetary.checked,
          notes: g("notes") || undefined, source: g("source") || undefined,
        };
        const lat = num("lat"), lng = num("lng");
        if (lat != null && lng != null) e.coords = { lat, lng };
        const c = {};
        ["phone","whatsapp","instagram","website","email"].forEach((k) => { const v = g("c_" + k); if (v) c[k] = v; });
        if (Object.keys(c).length) e.contact = c;
        const people = readRepeat("people-list", PERSON_FIELDS, "name");
        if (people.length) e.people = people;
        const cps = readRepeat("cp-list", CP_FIELDS, "location");
        if (cps.length) e.collectionPoints = cps;
        return e;
      }

      async function save() {
        statusEl.textContent = "Guardando…";
        let payload;
        try { payload = collect(); } catch (err) { statusEl.textContent = "No se pudieron leer los datos del formulario."; return; }
        // Los centros ya no usan imágenes: el identificador se genera solo.
        if (mode === "create" && !payload.filename) {
          payload.filename = "reg-" + (slug(payload.title) || "centro") + "-" + Math.random().toString(36).slice(2, 7);
        }
        const url = mode === "create" ? "/api/admin/points" : "/api/admin/points/" + encodeURIComponent(editingName);
        try {
          const r = await fetch(url, {
            method: mode === "create" ? "POST" : "PATCH",
            headers: { "content-type": "application/json" },
            body: JSON.stringify(payload),
          });
          if (r.status === 401) { alert("No autorizado. Recarga la página."); location.reload(); return; }
          if (!r.ok) { statusEl.textContent = "Error: " + (await r.text()); return; }
          dlg.close();
          await refresh(); // re-renderiza sin recargar el navegador
        } catch (err) { statusEl.textContent = "Error de red"; }
      }

      async function del(filename) {
        if (!confirm("¿Borrar «" + filename + "»? Esto afecta la base en vivo.")) return;
        const r = await fetch("/api/admin/points/" + encodeURIComponent(filename), {
          method: "DELETE",
        });
        if (r.status === 401) { alert("No autorizado. Recarga la página."); location.reload(); return; }
        if (r.ok) await refresh(); else alert("Error: " + (await r.text()));
      }

      document.getElementById("new-btn").addEventListener("click", () => openForm(null));
      document.getElementById("save").addEventListener("click", save);
      document.getElementById("cancel").addEventListener("click", () => dlg.close());
      document.getElementById("copy-url").addEventListener("click", () => {
        navigator.clipboard.writeText(location.href);
        const b = document.getElementById("copy-url");
        const prev = b.innerHTML;
        b.textContent = "¡Copiado!";
        setTimeout(() => (b.innerHTML = prev), 1500);
      });

      // Sidebar de filtros desplegable
      const regLayout = document.querySelector(".reg-layout");
      const filtersToggle = document.getElementById("filters-toggle");
      filtersToggle.addEventListener("click", () => {
        const hidden = regLayout.classList.toggle("filters-hidden");
        filtersToggle.setAttribute("aria-expanded", String(!hidden));
      });

      // Filas repetibles: agregar / quitar
      document.querySelector('[data-add="person"]').addEventListener("click", () => addPerson());
      document.querySelector('[data-add="cp"]').addEventListener("click", () => addCp());
      ["people-list", "cp-list"].forEach((id) =>
        document.getElementById(id).addEventListener("click", (e) => {
          const b = e.target.closest(".row-del");
          if (b) b.closest(".rrow").remove();
        }),
      );

      // ---- Vistas (navbar): Registros / Auditoría ----
      const ACT = { create: "Creó", update: "Editó", delete: "Borró" };
      let auditLoaded = false;
      async function loadAudit() {
        const tb = document.getElementById("audit-rows");
        tb.innerHTML = '<tr><td colspan="6">Cargando…</td></tr>';
        try {
          const r = await fetch("/api/admin/audit");
          if (!r.ok) { tb.innerHTML = '<tr><td colspan="6">No se pudo cargar.</td></tr>'; return; }
          const rows = await r.json();
          if (!rows.length) { tb.innerHTML = '<tr><td colspan="6">Sin movimientos de auditoría todavía.</td></tr>'; return; }
          tb.innerHTML = rows.map((a) => {
            const when = new Date(a.createdAt).toLocaleString("es-VE");
            const ua = (a.userAgent || "").replace(/\s*\(.*$/, "").slice(0, 40);
            const exists = !!byName[a.filename];
            const cls = exists ? "linked" : "gone";
            const tip = exists ? "Abrir para editar" : "Este registro ya no existe";
            return `<tr data-fn="${esc(a.filename)}" class="${cls}" title="${tip}"><td>${esc(when)}</td>` +
              `<td><span class="tag a-${esc(a.action)}">${ACT[a.action] || esc(a.action)}</span></td>` +
              `<td>${esc(a.title || a.filename)}</td><td>${esc(a.ip || "—")}</td>` +
              `<td>${esc(a.country || "—")}</td><td>${esc(ua || "—")}</td></tr>`;
          }).join("");
          auditLoaded = true;
        } catch { tb.innerHTML = '<tr><td colspan="6">Error de red.</td></tr>'; }
      }
      document.querySelectorAll(".tab").forEach((t) => {
        t.addEventListener("click", () => {
          const v = t.dataset.view;
          document.querySelectorAll(".tab").forEach((x) => x.classList.toggle("active", x === t));
          document.querySelectorAll(".view").forEach((p) => p.classList.toggle("active", p.id === "view-" + v));
          if (v === "auditoria" && !auditLoaded) loadAudit();
          if (v === "pendientes") loadPending();
          if (v === "usuarios") loadUsers();
        });
      });
      document.getElementById("audit-refresh").addEventListener("click", loadAudit);
      // Clic en una fila de auditoría → abre el editor de ese registro.
      document.getElementById("audit-rows").addEventListener("click", (ev) => {
        const tr = ev.target.closest("tr[data-fn]");
        if (!tr) return;
        const entry = byName[tr.dataset.fn];
        if (entry) openForm(entry);
        else alert("Este registro ya no existe (fue borrado).");
      });
      // ---- Tabla renderizada en JS: filtros (como la vista pública),
      // paginación (10/pág) y refresco sin recargar el navegador ----
      const PER_PAGE = 10;
      let DATA = ENTRIES.slice();
      let page = 0;

      const fCat = document.getElementById("f-category");
      const fCountry = document.getElementById("f-country");
      const fState = document.getElementById("f-state");
      const fUrg = document.getElementById("f-urgency");
      const fOrg = document.getElementById("f-org");
      const search = document.getElementById("search");
      const countEl = document.getElementById("count");
      const rowsEl = document.getElementById("rows");
      const pager = document.getElementById("pager");
      const prevBtn = document.getElementById("pg-prev");
      const nextBtn = document.getElementById("pg-next");
      const pageInfo = document.getElementById("pg-info");

      const esc = (s) => String(s == null ? "" : s).replace(/[&<>"]/g, (c) =>
        ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;" })[c]);
      const URG = { high: "Alta", medium: "Media", low: "Baja" };
      const uniq = (arr) => [...new Set(arr.filter(Boolean))].sort((a, b) => a.localeCompare(b, "es"));

      function fillSel(sel, values) {
        const first = sel.options[0];
        const prev = sel.value;
        sel.innerHTML = "";
        sel.appendChild(first);
        for (const v of values) { const o = document.createElement("option"); o.value = v; o.textContent = v; sel.appendChild(o); }
        sel.value = values.indexOf(prev) >= 0 ? prev : "";
      }
      function rebuildStates() {
        const c = fCountry.value;
        fillSel(fState, uniq(DATA.filter((e) => !c || (e.location?.country || "") === c).map((e) => e.location?.state || "")));
      }
      function rebuildOptions() {
        fillSel(fCountry, uniq(DATA.map((e) => e.location?.country || "")));
        fillSel(fOrg, uniq(DATA.map((e) => e.organization || "")));
        rebuildStates();
      }
      function getFiltered() {
        const cat = fCat.value, co = fCountry.value, st = fState.value, ur = fUrg.value, og = fOrg.value;
        const q = search.value.trim().toLowerCase();
        return DATA.filter((e) => {
          const text = (e.title + " " + (e.organization || "") + " " + (e.location?.state || "") + " " + (e.location?.city || "")).toLowerCase();
          return (!cat || e.category === cat) && (!co || (e.location?.country || "") === co) &&
            (!st || (e.location?.state || "") === st) && (!ur || (e.urgency || "") === ur) &&
            (!og || (e.organization || "") === og) && (!q || text.includes(q));
        });
      }
      function rowHtml(e) {
        const cat = e.category === "center" ? "Centro" : "Profesional";
        const urg = URG[e.urgency || ""] || "—";
        const fn = esc(e.filename);
        const editIcon = '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 20h9M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4z"/></svg>';
        const delIcon = '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 6h18M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2m2 0v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6"/></svg>';
        return `<tr><td>${esc(e.title)}</td><td>${esc(e.organization || "—")}</td><td><span class="tag tag-${e.category}">${cat}</span></td>` +
          `<td>${esc(e.location?.state || "—")}</td><td>${urg}</td>` +
          `<td class="actions"><button type="button" class="icon-btn edit" data-fn="${fn}" title="Editar" aria-label="Editar">${editIcon}</button>` +
          `<button type="button" class="icon-btn danger del" data-fn="${fn}" title="Borrar" aria-label="Borrar">${delIcon}</button></td></tr>`;
      }
      function render() {
        const filtered = getFiltered();
        const pages = Math.max(1, Math.ceil(filtered.length / PER_PAGE));
        page = Math.min(Math.max(page, 0), pages - 1);
        rowsEl.innerHTML = filtered.slice(page * PER_PAGE, page * PER_PAGE + PER_PAGE).map(rowHtml).join("");
        countEl.textContent = filtered.length;
        document.getElementById("count-c").textContent = filtered.filter((e) => e.category === "center").length;
        document.getElementById("count-p").textContent = filtered.filter((e) => e.category === "professional").length;
        pageInfo.textContent = "Página " + (page + 1) + " de " + pages;
        prevBtn.disabled = page === 0;
        nextBtn.disabled = page >= pages - 1;
        pager.hidden = filtered.length <= PER_PAGE;
      }
      function applyFilters() { page = 0; render(); }

      rowsEl.addEventListener("click", (ev) => {
        const b = ev.target.closest("button"); if (!b) return;
        const fn = b.dataset.fn;
        if (b.classList.contains("edit")) openForm(byName[fn]);
        else if (b.classList.contains("del")) del(fn);
      });
      fCountry.addEventListener("change", () => { rebuildStates(); applyFilters(); });
      [fCat, fState, fUrg, fOrg].forEach((el) => el.addEventListener("change", applyFilters));
      search.addEventListener("input", applyFilters);
      prevBtn.addEventListener("click", () => { page--; render(); });
      nextBtn.addEventListener("click", () => { page++; render(); });
      document.getElementById("f-clear").addEventListener("click", () => {
        fCat.value = ""; fCountry.value = ""; fUrg.value = ""; fOrg.value = ""; search.value = "";
        rebuildStates(); applyFilters();
      });

      // Refresco en vivo: re-consulta la API y re-renderiza (sin recargar).
      async function refresh() {
        try {
          const r = await fetch("/api/admin/points");
          if (!r.ok) return;
          DATA = await r.json();
          byName = Object.fromEntries(DATA.map((e) => [e.filename, e]));
          rebuildOptions();
          render();
          auditLoaded = false; // hubo un cambio: recargar la auditoría al abrirla
          loadPending();
        } catch {}
      }

      rebuildOptions();
      render();

      async function loadPending() {
        const tb = document.getElementById("pend-rows");
        tb.innerHTML = '<tr><td colspan="6">Cargando…</td></tr>';
        try {
          const rows = await (await fetch("/api/admin/submissions?status=pending")).json();
          const badge = document.getElementById("pend-count");
          badge.textContent = rows.length; badge.hidden = rows.length === 0;
          if (!rows.length) { tb.innerHTML = '<tr><td colspan="6">Sin pendientes.</td></tr>'; return; }
          tb.innerHTML = rows.map((s) => {
            const p = s.payload || {};
            const when = new Date(s.createdAt).toLocaleString("es-VE");
            const cat = p.category === "professional" ? "Profesional" : "Centro";
            const loc = [p.location?.state, p.location?.city].filter(Boolean).join(" / ") || "—";
            return `<tr data-id="${esc(s.id)}"><td>${esc(when)}</td><td>${esc(s.submittedBy?.nickname || "—")}</td>`
              + `<td>${cat}</td><td>${esc(p.title || "—")}</td><td>${esc(loc)}</td>`
              + `<td class="actions"><button class="icon-btn approve" data-id="${esc(s.id)}" title="Aprobar">✓</button>`
              + `<button class="icon-btn danger reject" data-id="${esc(s.id)}" title="Rechazar">✕</button></td></tr>`;
          }).join("");
        } catch { tb.innerHTML = '<tr><td colspan="6">Error.</td></tr>'; }
      }
      document.getElementById("pend-rows").addEventListener("click", async (ev) => {
        const b = ev.target.closest("button"); if (!b) return;
        const id = b.dataset.id;
        if (b.classList.contains("approve")) {
          await fetch(`/api/admin/submissions/${id}/approve`, { method: "POST" });
          await loadPending(); await refresh();
        } else if (b.classList.contains("reject")) {
          if (!confirm("¿Rechazar esta sugerencia?")) return;
          await fetch(`/api/admin/submissions/${id}/reject`, { method: "POST", headers: { "content-type": "application/json" }, body: "{}" });
          await loadPending();
        }
      });
      document.getElementById("pend-refresh").addEventListener("click", loadPending);

      async function loadUsers() {
        const tb = document.getElementById("users-rows");
        tb.innerHTML = '<tr><td colspan="4">Cargando…</td></tr>';
        try {
          const rows = await (await fetch("/api/admin/users")).json();
          tb.innerHTML = rows.map((u) => {
            const when = new Date(u.createdAt).toLocaleDateString("es-VE");
            const isAdmin = u.role === "admin";
            const action = isAdmin
              ? `<button class="icon-btn role-btn" data-id="${esc(u.id)}" data-role="user">Quitar admin</button>`
              : `<button class="icon-btn role-btn" data-id="${esc(u.id)}" data-role="admin">Hacer admin</button>`;
            return `<tr><td>${esc(u.nickname)}</td><td>${isAdmin ? "Admin" : "Usuario"}</td><td>${esc(when)}</td><td class="actions">${action}</td></tr>`;
          }).join("");
        } catch { tb.innerHTML = '<tr><td colspan="4">Error.</td></tr>'; }
      }
      document.getElementById("users-rows").addEventListener("click", async (ev) => {
        const b = ev.target.closest(".role-btn"); if (!b) return;
        const r = await fetch(`/api/admin/users/${b.dataset.id}/role`, { method: "POST", headers: { "content-type": "application/json" }, body: JSON.stringify({ role: b.dataset.role }) });
        if (!r.ok) alert(await r.text());
        await loadUsers();
      });
      document.getElementById("users-refresh").addEventListener("click", loadUsers);

      (async function gate() {
        let me = null;
        try { me = await (await fetch("/api/auth/me")).json(); } catch {}
        if (!me) {
          document.body.innerHTML = '<form id="lg" style="max-width:280px;margin:80px auto;font-family:system-ui;display:flex;flex-direction:column;gap:10px">'
            + '<h2>Admin · iniciar sesión</h2>'
            + '<input name="nickname" placeholder="Apodo" required>'
            + '<input name="password" type="password" placeholder="Clave" required>'
            + '<p id="lgerr" style="color:#d64533;min-height:16px;margin:0"></p>'
            + '<button>Entrar</button></form>';
          document.getElementById("lg").addEventListener("submit", async (e) => {
            e.preventDefault();
            const f = e.target;
            const r = await fetch("/api/auth/login", { method: "POST", headers: { "content-type": "application/json" },
              body: JSON.stringify({ nickname: f.nickname.value.trim(), password: f.password.value }) });
            if (r.ok) location.reload(); else document.getElementById("lgerr").textContent = await r.text();
          });
          return;
        }
        if (me.role !== "admin") {
          document.body.innerHTML = '<p style="padding:40px;font-family:system-ui">No autorizado. Tu cuenta no es de administrador.</p>';
          return;
        }
        // admin confirmed → load data
        await refresh();
      })();
    </script>

    <style is:global>
      :root {
        --ink: #14213d; --ink-soft: #243456; --paper: #f3f4f7; --card: #ffffff;
        --gold: #e8a33d; --gold-deep: #c9821a; --urgent: #d64533;
        --line: #e3e6ec; --text: #1c2433; --muted: #5b6472;
        --font-display: "Archivo", system-ui, sans-serif;
        --font-body: "Public Sans", system-ui, sans-serif;
        --font-mono: "Space Mono", ui-monospace, monospace;
      }
      * { box-sizing: border-box; }
      body { font-family: var(--font-body); margin: 0; background: var(--paper); color: var(--text); -webkit-font-smoothing: antialiased; }

      .warn { background: var(--urgent); color: #fff; padding: 10px 20px; font-family: var(--font-mono); font-size: 12px; letter-spacing: 0.02em; }

      .bar { display: flex; align-items: center; justify-content: space-between; padding: 20px; gap: 12px; flex-wrap: wrap; }
      .bar h1 { font-family: var(--font-display); font-weight: 800; font-size: 20px; letter-spacing: -0.01em; color: var(--ink); margin: 0; }
      .bar-actions { display: flex; gap: 8px; }

      .btn {
        display: inline-flex; align-items: center; gap: 7px;
        font-family: var(--font-display); font-weight: 700; font-size: 13px;
        padding: 9px 14px; border-radius: 9px; border: 1px solid var(--line);
        background: var(--card); color: var(--ink); cursor: pointer;
        transition: background 0.15s, border-color 0.15s, color 0.15s;
      }
      .btn svg { width: 16px; height: 16px; fill: none; stroke: currentColor; stroke-width: 1.9; stroke-linecap: round; stroke-linejoin: round; flex-shrink: 0; }
      .btn.ghost:hover { border-color: var(--ink); }
      .btn.primary { background: var(--gold); border-color: var(--gold); color: var(--ink); }
      .btn.primary:hover { background: var(--gold-deep); border-color: var(--gold-deep); color: #fff; }
      .btn:disabled { opacity: 0.45; cursor: default; }
      .btn:focus-visible { outline: 2px solid var(--gold); outline-offset: 2px; }

      /* Registros: layout con sidebar de filtros desplegable */
      .reg-layout { display: flex; gap: 18px; align-items: flex-start; padding: 16px 20px 0; }
      .sidebar { flex: 0 0 230px; position: sticky; top: 16px; background: var(--card); border: 1px solid var(--line); border-radius: 12px; padding: 16px; }
      .sidebar-head { display: flex; align-items: center; justify-content: space-between; gap: 10px; margin-bottom: 14px; }
      .sidebar-head h2 { font-family: var(--font-display); font-weight: 800; font-size: 15px; color: var(--ink); margin: 0; }
      .sidebar-head .btn { font-size: 12px; padding: 6px 10px; }
      .main-col { flex: 1; min-width: 0; }
      .reg-layout.filters-hidden .sidebar { display: none; }
      .main-col .view-tools { margin: 0 0 14px; }
      .table-wrap { overflow-x: auto; -webkit-overflow-scrolling: touch; margin: 0 0 16px; border-radius: 12px; }
      .main-col table { width: 100%; margin: 0; }
      .main-col .pager { margin: 8px 0 0; }
      .vt-left { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }

      .filters { display: flex; flex-direction: column; gap: 12px; margin: 0; }
      .filters label { gap: 5px; }
      .filters select, .filters input { width: 100%; font-family: var(--font-body); font-size: 13px; padding: 9px 11px; border: 1px solid var(--line); border-radius: 9px; background: var(--card); color: var(--text); text-transform: none; }
      .filters select:focus, .filters input:focus { outline: none; border-color: var(--gold); }

      @media (max-width: 820px) {
        .reg-layout { flex-direction: column; }
        .sidebar { position: static; flex: none; width: 100%; }
        .filters { flex-direction: row; flex-wrap: wrap; }
        .filters label { flex: 1; min-width: 150px; }
      }

      .count { margin: 12px 20px; font-family: var(--font-mono); font-size: 12px; color: var(--muted); }
      .count #count { color: var(--ink); font-weight: 700; }
      .nodb { margin: 16px 20px; background: var(--card); border: 1px dashed var(--line); border-radius: 10px; padding: 16px; color: var(--muted); }
      .nodb code { font-family: var(--font-mono); color: var(--ink); }

      table { width: calc(100% - 40px); margin: 0 20px 20px; border-collapse: collapse; background: var(--card); border: 1px solid var(--line); border-radius: 12px; overflow: hidden; }
      th, td { text-align: left; padding: 11px 14px; border-bottom: 1px solid #eef0f4; font-size: 14px; }
      th { background: var(--ink); color: #fff; font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.06em; text-transform: uppercase; }
      tbody tr:last-child td { border-bottom: none; }
      tbody tr:hover { background: #fafbfc; }
      td.actions { white-space: nowrap; text-align: right; }

      .tag { font-family: var(--font-mono); font-size: 10.5px; padding: 2px 9px; border-radius: 20px; border: 1px solid var(--line); color: var(--muted); }
      .tag-center { color: #2563eb; border-color: #cdddfb; background: #eff5ff; }
      .tag-professional { color: #dc2626; border-color: #f5cccc; background: #fef2f2; }

      .icon-btn {
        display: inline-flex; align-items: center; justify-content: center;
        width: 32px; height: 32px; margin-left: 6px; padding: 0;
        border: 1px solid var(--line); border-radius: 8px; background: var(--card);
        color: var(--ink-soft); cursor: pointer; transition: background 0.15s, border-color 0.15s, color 0.15s;
      }
      .icon-btn svg { width: 16px; height: 16px; fill: none; stroke: currentColor; stroke-width: 1.8; stroke-linecap: round; stroke-linejoin: round; }
      .icon-btn:hover { border-color: var(--ink); }
      .icon-btn.danger { color: var(--urgent); }
      .icon-btn.danger:hover { border-color: var(--urgent); background: #fef2f2; }

      .pager { display: flex; align-items: center; justify-content: center; gap: 14px; margin: 0 20px 40px; }
      #pg-info { font-family: var(--font-mono); font-size: 12px; color: var(--muted); }

      .map-pick { display: flex; flex-direction: column; gap: 4px; }
      .map-pick-label { font-size: 12px; color: var(--muted); }
      #pick-map { height: 240px; border: 1px solid var(--line); border-radius: 10px; overflow: hidden; }

      dialog { width: min(780px, 94vw); max-height: 92vh; border: none; border-radius: 16px; padding: 0; box-shadow: 0 24px 70px rgba(20,33,61,0.4); overflow: hidden; }
      dialog::backdrop { background: rgba(20,33,61,0.5); }
      form { padding: 24px; max-height: 92vh; overflow-y: auto; -webkit-overflow-scrolling: touch; }
      form h2 { font-family: var(--font-display); font-weight: 800; font-size: 18px; color: var(--ink); margin: 0 0 18px; }
      .grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; }
      label { display: flex; flex-direction: column; gap: 4px; font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.06em; text-transform: uppercase; color: var(--muted); }
      .wide { grid-column: 1 / -1; }
      .check { flex-direction: row; align-items: center; gap: 8px; grid-column: 1 / -1; text-transform: none; font-family: var(--font-body); font-size: 13px; color: var(--text); }
      input, select, textarea { font-family: var(--font-body); font-size: 14px; padding: 9px 11px; border: 1px solid var(--line); border-radius: 9px; background: var(--card); color: var(--text); }
      input:focus, select:focus, textarea:focus { outline: none; border-color: var(--gold); }
      input[readonly] { background: var(--paper); }
      fieldset { grid-column: 1 / -1; border: 1px solid var(--line); border-radius: 10px; }
      legend { font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.06em; text-transform: uppercase; color: var(--muted); padding: 0 6px; }
      .form-status { color: var(--urgent); font-size: 13px; min-height: 18px; }
      .form-actions {
        display: flex; justify-content: flex-end; gap: 8px;
        position: sticky; bottom: -24px; margin: 8px -24px -24px; padding: 14px 24px;
        background: var(--card); border-top: 1px solid var(--line);
      }

      .repeat { padding: 10px 12px 12px; }
      .rrows { display: flex; flex-direction: column; gap: 6px; margin-bottom: 8px; }
      .rrow { display: flex; gap: 6px; align-items: center; }
      .rrow input { flex: 1; min-width: 0; font-size: 13px; padding: 8px 10px; }
      .rrow .icon-btn { flex-shrink: 0; width: 30px; height: 30px; margin-left: 0; }
      .add-row { font-size: 12px; padding: 7px 12px; }
      .add-row svg { width: 14px; height: 14px; }
      .repeat .rrows:empty::before { content: "Sin elementos. Usa el botón para agregar."; font-size: 12px; color: var(--muted); }

      .tabs { display: flex; gap: 2px; padding: 0 20px; margin-top: 6px; border-bottom: 1px solid var(--line); }
      .tab {
        display: inline-flex; align-items: center; gap: 8px;
        font-family: var(--font-display); font-weight: 700; font-size: 14px;
        padding: 12px 16px; border: none; background: none; color: var(--muted);
        cursor: pointer; border-bottom: 2px solid transparent; margin-bottom: -1px;
        transition: color 0.15s, border-color 0.15s;
      }
      .tab svg { width: 18px; height: 18px; fill: none; stroke: currentColor; stroke-width: 1.8; stroke-linecap: round; stroke-linejoin: round; }
      .tab:hover { color: var(--ink); }
      .tab.active { color: var(--ink); border-bottom-color: var(--gold); }
      .view { display: none; }
      .view.active { display: block; }
      .view-tools { display: flex; align-items: center; justify-content: space-between; gap: 12px; flex-wrap: wrap; margin: 16px 20px 12px; }
      .view-tools .count { margin: 0; }

      .audit-note { font-size: 12.5px; color: var(--muted); margin: 0; line-height: 1.45; flex: 1; min-width: 220px; }
      .audit-wrap { margin: 0 20px 40px; max-height: 68vh; overflow: auto; border: 1px solid var(--line); border-radius: 10px; }
      .audit-table { width: 100%; border-collapse: collapse; }
      .audit-table th { position: sticky; top: 0; background: var(--ink); color: #fff; font-family: var(--font-mono); font-size: 10.5px; letter-spacing: 0.05em; text-transform: uppercase; text-align: left; padding: 9px 10px; }
      .audit-table td { font-size: 12.5px; padding: 8px 10px; border-bottom: 1px solid #eef0f4; white-space: nowrap; color: var(--text); }
      .audit-table td:nth-child(3) { white-space: normal; }
      .audit-table tbody tr.linked { cursor: pointer; }
      .audit-table tbody tr.linked:hover td { background: #f6f8fb; }
      .audit-table tbody tr.gone td { color: #9aa3b0; }
      .a-create { color: #2f7d32; border-color: #cde8cf; background: #eef6ee; }
      .a-update { color: var(--gold-deep); border-color: #f0dcb4; background: #fbf3e3; }
      .a-delete { color: var(--urgent); border-color: #f5cccc; background: #fef2f2; }
      .tab-badge { background: var(--gold); color: #14213d; border-radius: 20px; padding: 1px 7px; font-size: 11px; font-weight: 700; margin-left: 4px; }
      .audit-table .approve { color: #2f7d32; } .audit-table .reject { color: var(--urgent); }

      @media (max-width: 640px) {
        /* Encabezado y barras: menos aire lateral en móvil */
        .warn { padding: 9px 14px; }
        .bar { padding: 14px; }
        .tabs { padding: 0 14px; }
        .view-tools { margin: 14px 14px 12px; }
        .reg-layout { padding: 14px 14px 0; }
        .count { margin: 10px 14px; }
        .audit-wrap, .pager { margin-left: 14px; margin-right: 14px; }

        /* Tabla de registros: desplázala en horizontal sin romper el layout */
        table { width: 100%; margin: 0; }
        .main-col table { min-width: 540px; }
        th, td { padding: 9px 11px; font-size: 13px; }

        /* Modal: ocupa casi toda la pantalla y deja respirar el formulario */
        dialog { width: 96vw; max-height: 95vh; }
        form { padding: 16px; max-height: 95vh; }
        form h2 { font-size: 16px; margin-bottom: 14px; }
        .grid { grid-template-columns: 1fr; gap: 11px; }
        /* El sub-grid de Contacto también a una columna */
        fieldset .grid { grid-template-columns: 1fr; }
        #pick-map { height: 200px; }
        .form-actions { margin: 8px -16px -16px; padding: 12px 16px; }
        .form-actions .btn { flex: 1; justify-content: center; }

        /* Filas repetibles (Personas / Puntos): apila los inputs */
        .rrow { flex-wrap: wrap; position: relative; padding-right: 38px; }
        .rrow input { flex: 1 1 100%; }
        .rrow .icon-btn { position: absolute; top: 0; right: 0; }
      }
    </style>
  </body>
